# --- DIPENDENZE ---
# Non caricare mai le librerie locali; verranno reinstallate tramite npm install
node_modules/
jspm_packages/

# --- SICUREZZA & CONFIGURAZIONE ---
# Fondamentale per proteggere le chiavi di Mongoose e le porte di Express
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- LOG ---
# Morgan e npm generano questi file; non servono nel repository
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- RUNTIME & DOCKER ---
# Se usi Docker, evita di includere i file di processo o i pid
pids
*.pid
*.seed
*.pid.lock

# --- DIRECTORY DI SISTEMA & EDITOR ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.sublime-project
*.sublime-workspace